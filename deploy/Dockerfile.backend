FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1
RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN pip install --break-system-packages --no-cache-dir bcrypt passlib email-validator fastapi uvicorn sqlalchemy asyncpg alembic redis python-jose python-multipart pydantic pydantic-settings httpx google-auth python-dotenv boto3 aiosqlite fpdf2
COPY backend/ .
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s CMD curl -f http://localhost:8000/api/health || exit 1
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
