# =============================================================================
# .env.example — Variables d'environnement pour le déploiement Kleia-up
# =============================================================================
# Copiez ce fichier en deploy/.env et remplissez les valeurs.
# Ce fichier .env est la source UNIQUE utilisée par docker-compose.yml
# (référencé par tous les services : backend, db).
# =============================================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=kleia_lms
POSTGRES_USER=kleia_user
POSTGRES_PASSWORD=change-me-in-production

# --- Connexion base de données (backend) ---
DATABASE_URL=postgresql+asyncpg://kleia_user:change-me-in-production@db:5432/kleia_lms

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Google OAuth2 (OIDC) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Redis ---
REDIS_URL=redis://cache:6379/0

# --- S3-compatible (OVH Object Storage) ---
S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
S3_BUCKET_NAME=kleia-up-media
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=gra

# --- Application ---
APP_NAME=Kleia-up LMS
VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
